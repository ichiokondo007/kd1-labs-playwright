{"version":3,"sources":["../src/create-cli.ts","../src/i18n/messages.ts","../src/ui/color.ts","../src/ui/banner.ts","../src/ui/banner-renderer.ts","../src/ui/color-resolve.ts","../src/ui/theme.ts","../src/ui/logger.ts","../src/ui/prompt-config.ts","../src/ui/screen.ts","../src/create-cli-from-config.ts","../src/config/nav-menu-schema.ts","../src/runner.ts","../src/ui/pause.ts","../src/ui/table.ts","../src/services/command.service.ts","../src/ui/spinner.ts"],"sourcesContent":["import { select } from \"@inquirer/prompts\";\nimport { defaultMessages, type Messages } from \"./i18n/messages.js\";\nimport type { CliConfig, MenuDefinition } from \"./types.js\";\nimport { createDefaultBannerRenderer } from \"./ui/banner-renderer.js\";\nimport { defaultColorPalette, mergeColorPalette } from \"./ui/color.js\";\nimport {\n  resolveBannerColorToken,\n  resolvePartialColors,\n} from \"./ui/color-resolve.js\";\nimport { createLogger } from \"./ui/logger.js\";\nimport { SELECT_PAGE_SIZE, SELECT_THEME } from \"./ui/prompt-config.js\";\nimport { showScreen } from \"./ui/screen.js\";\nimport { createThemeFromPartialColors } from \"./ui/theme.js\";\n\nfunction buildChoices(menus: MenuDefinition[], messages: Messages) {\n  const menuChoices = menus.map((m) => ({\n    name: m.name,\n    value: m.value,\n    description: m.description,\n  }));\n\n  return [\n    ...menuChoices,\n    { name: messages.exit, value: \"__exit__\" },\n  ];\n}\n\n/**\n * Create and start an interactive CLI with the given configuration.\n *\n * Usage:\n * ```ts\n * createCli({\n *   banner: \"MY PROJECT\",\n *   title: \"My DevTool\",\n *   menus: [\n *     { name: \"Run tests\", value: \"test\", handler: async () => { ... } },\n *   ],\n * });\n * ```\n */\nexport async function createCli(config: CliConfig): Promise<void> {\n  const {\n    menus,\n    title = \"Main Menu\",\n    banner,\n    bannerColor,\n    screen,\n    colors,\n    theme: themeOption,\n    bannerRenderer: bannerRendererOption,\n    messages = defaultMessages,\n  } = config;\n\n  const resolvedColors = resolvePartialColors(colors);\n\n  const mergedPalette = themeOption\n    ? defaultColorPalette\n    : mergeColorPalette(resolvedColors);\n\n  const theme = themeOption ?? createThemeFromPartialColors(resolvedColors);\n\n  const bannerRenderer =\n    bannerRendererOption ??\n    createDefaultBannerRenderer(mergedPalette);\n\n  const log = createLogger(theme);\n  const choices = buildChoices(menus, messages);\n  const handlerMap = new Map<string, MenuDefinition[\"handler\"]>();\n  for (const m of menus) {\n    handlerMap.set(m.value, m.handler);\n  }\n\n  const screenOptions = {\n    banner,\n    bannerColor: resolveBannerColorToken(bannerColor, mergedPalette),\n    bannerRenderer,\n    screen,\n  };\n  showScreen(title, screenOptions);\n\n  while (true) {\n    const choice = await select({\n      message: \"Select an action\\n\",\n      choices,\n      loop: false,\n      pageSize: SELECT_PAGE_SIZE,\n      theme: SELECT_THEME,\n    }).catch(() => \"__interrupted__\" as const);\n\n    if (choice === \"__interrupted__\") {\n      log.warn(\"\\nBye! 👋\");\n      process.exit(0);\n    }\n\n    if (choice === \"__exit__\") {\n      log.info(\"\\nBye! 👋\\n\");\n      process.exit(0);\n    }\n\n    const handler = handlerMap.get(choice);\n    if (handler) {\n      try {\n        await handler();\n      } catch {\n        log.error(messages.errorReturnToTop);\n      }\n    }\n\n    showScreen(title, screenOptions);\n  }\n}\n","import type { NavMenuMessageOverrides } from \"../config/nav-menu-schema.js\";\n\nexport interface Messages {\n  /** e.g. \"✅ 3 ステップ完了\" */\n  stepsCompleted: (total: number) => string;\n  /** e.g. \"(Ctrl+C で停止)\" */\n  ctrlCToStop: string;\n  /** Navigation: back label */\n  back: string;\n  /** Navigation: top label */\n  top: string;\n  /** Navigation: exit label */\n  exit: string;\n  /** Error shown inside JSON-driven CLI */\n  errorOccurred: string;\n  /** Error shown inside handler-based CLI */\n  errorReturnToTop: string;\n  /** Pause prompt */\n  pressEnterToReturn: string;\n}\n\nexport const jaMessages: Messages = {\n  stepsCompleted: (total) => `✅ ${total} ステップ完了`,\n  ctrlCToStop: \"(Ctrl+C で停止)\",\n  back: \"◀ 戻る\",\n  top: \"⏫ TOPへ\",\n  exit: \"❌ 終了\",\n  errorOccurred: \"\\n⚠ エラーが発生しました。\\n\",\n  errorReturnToTop: \"\\n⚠ エラーが発生しました。TOPメニューに戻ります。\\n\",\n  pressEnterToReturn: \"Enter で戻る...\",\n};\n\nexport const enMessages: Messages = {\n  stepsCompleted: (total) => `✅ ${total} steps completed`,\n  ctrlCToStop: \"(Ctrl+C to stop)\",\n  back: \"◀ Back\",\n  top: \"⏫ Top\",\n  exit: \"❌ Exit\",\n  errorOccurred: \"\\n⚠ An error occurred.\\n\",\n  errorReturnToTop: \"\\n⚠ An error occurred. Returning to top menu.\\n\",\n  pressEnterToReturn: \"Press Enter to return...\",\n};\n\n/** Default messages (Japanese for backward compatibility) */\nexport const defaultMessages: Messages = jaMessages;\n\nfunction applyMessageOverrides(\n  base: Messages,\n  o: NavMenuMessageOverrides,\n): Messages {\n  const stepsTpl = o.stepsCompleted;\n  return {\n    stepsCompleted: stepsTpl\n      ? (total) => stepsTpl.replaceAll(\"{total}\", String(total))\n      : base.stepsCompleted,\n    ctrlCToStop: o.ctrlCToStop ?? base.ctrlCToStop,\n    back: o.back ?? base.back,\n    top: o.top ?? base.top,\n    exit: o.exit ?? base.exit,\n    errorOccurred: o.errorOccurred ?? base.errorOccurred,\n    errorReturnToTop: o.errorReturnToTop ?? base.errorReturnToTop,\n    pressEnterToReturn: o.pressEnterToReturn ?? base.pressEnterToReturn,\n  };\n}\n\n/**\n * Base messages from `locale`, then apply JSON `messageOverrides`.\n * Does not apply `config.labels` (handled at call site).\n */\nexport function resolveMessagesForNavConfig(\n  locale: \"ja\" | \"en\" | undefined,\n  overrides: NavMenuMessageOverrides | undefined,\n): Messages {\n  const base = locale === \"en\" ? enMessages : jaMessages;\n  return overrides ? applyMessageOverrides(base, overrides) : base;\n}\n","export type ColorPalette = {\n  blue: string;\n  cyan: string;\n  orange: string;\n  green: string;\n  red: string;\n  gray: string;\n  reset: string;\n};\n\nexport const defaultColorPalette: ColorPalette = {\n  blue: \"\\x1b[38;5;39m\",\n  cyan: \"\\x1b[38;5;45m\",\n  orange: \"\\x1b[38;5;208m\",\n  green: \"\\x1b[38;5;82m\",\n  red: \"\\x1b[38;5;196m\",\n  gray: \"\\x1b[90m\",\n  reset: \"\\x1b[0m\",\n};\n\n/** Same as `defaultColorPalette` — kept for backward compatibility. */\nexport const color = defaultColorPalette;\n\nexport function mergeColorPalette(\n  partial?: Partial<ColorPalette>,\n): ColorPalette {\n  return { ...defaultColorPalette, ...partial };\n}\n","import figlet from \"figlet\";\nimport type { BannerConfig } from \"../types.js\";\nimport { defaultColorPalette, type ColorPalette } from \"./color.js\";\n\nconst DEFAULT_BANNER = `\n+-------------------------------------------------------------------+\n|                                                                   |\n| ███╗   ██╗ █████╗ ██╗   ██╗███╗   ███╗███████╗███╗   ██╗██╗   ██╗ |\n| ████╗  ██║██╔══██╗██║   ██║████╗ ████║██╔════╝████╗  ██║██║   ██║ |\n| ██╔██╗ ██║███████║██║   ██║██╔████╔██║█████╗  ██╔██╗ ██║██║   ██║ |\n| ██║╚██╗██║██╔══██║╚██╗ ██╔╝██║╚██╔╝██║██╔══╝  ██║╚██╗██║██║   ██║ |\n| ██║ ╚████║██║  ██║ ╚████╔╝ ██║ ╚═╝ ██║███████╗██║ ╚████║╚██████╔╝ |\n| ╚═╝  ╚═══╝╚═╝  ╚═╝  ╚═══╝  ╚═╝     ╚═╝╚══════╝╚═╝  ╚═══╝ ╚═════╝  |\n|                                            powered by @kd1-labs   |\n+-------------------------------------------------------------------+\n`;\n\n/**\n * Print a banner to the console.\n * @param banner - Custom ASCII art string, a print function, or undefined for default\n * @param bannerColor - ANSI color code (defaults to blue)\n */\nexport function printBanner(\n  banner?: BannerConfig | (() => void),\n  bannerColor?: string,\n  colorPalette: ColorPalette = defaultColorPalette,\n): void {\n  if (typeof banner === \"function\") {\n    banner();\n    return;\n  }\n\n  let text = DEFAULT_BANNER;\n  if (typeof banner === \"string\") {\n    text = figlet.textSync(banner);\n  } else if (banner?.type === \"text\") {\n    text = figlet.textSync(banner.text);\n  } else if (banner?.type === \"file\") {\n    text = banner.content ?? DEFAULT_BANNER;\n  }\n  const colorCode = bannerColor ?? colorPalette.blue;\n  console.log(`${colorCode}${text}${colorPalette.reset}`);\n}\n","import type { BannerConfig } from \"../types.js\";\nimport { defaultColorPalette, type ColorPalette } from \"./color.js\";\nimport { printBanner } from \"./banner.js\";\n\n/**\n * Renders the CLI banner. Override in consuming projects if needed.\n */\nexport interface BannerRenderer {\n  print(\n    banner?: BannerConfig | (() => void),\n    bannerColor?: string,\n  ): void;\n}\n\nexport function createDefaultBannerRenderer(\n  colorPalette: ColorPalette = defaultColorPalette,\n): BannerRenderer {\n  return {\n    print(banner, bannerColor): void {\n      printBanner(banner, bannerColor, colorPalette);\n    },\n  };\n}\n\nexport const defaultBannerRenderer: BannerRenderer =\n  createDefaultBannerRenderer();\n","import { defaultColorPalette, type ColorPalette } from \"./color.js\";\n\nconst PRESET_KEYS: readonly (keyof ColorPalette)[] = [\n  \"blue\",\n  \"cyan\",\n  \"orange\",\n  \"green\",\n  \"red\",\n  \"gray\",\n  \"reset\",\n] as const;\n\nfunction presetKeyFromString(value: string): keyof ColorPalette | undefined {\n  const lower = value.toLowerCase();\n  for (const k of PRESET_KEYS) {\n    if (lower === k) {\n      return k;\n    }\n  }\n  return undefined;\n}\n\n/**\n * Resolves a single color value: preset name (case-insensitive) uses `palette`,\n * otherwise the string is returned as-is (e.g. raw ANSI).\n */\nexport function resolveColorToken(\n  value: string,\n  palette: ColorPalette,\n): string {\n  const key = presetKeyFromString(value);\n  if (key !== undefined) {\n    return palette[key];\n  }\n  return value;\n}\n\n/**\n * Resolves `colors` partial: each value may be a preset name (resolved with\n * {@link defaultColorPalette}) or a raw ANSI string.\n */\nexport function resolvePartialColors(\n  partial: Partial<ColorPalette> | undefined,\n): Partial<ColorPalette> | undefined {\n  if (!partial) {\n    return undefined;\n  }\n  const out: Partial<ColorPalette> = {};\n  for (const key of PRESET_KEYS) {\n    const v = partial[key];\n    if (v !== undefined) {\n      out[key] = resolveColorToken(v, defaultColorPalette);\n    }\n  }\n  return out;\n}\n\n/**\n * Resolves banner color: preset name uses merged palette slot, undefined stays undefined.\n */\nexport function resolveBannerColorToken(\n  token: string | undefined,\n  palette: ColorPalette,\n): string | undefined {\n  if (token === undefined) {\n    return undefined;\n  }\n  return resolveColorToken(token, palette);\n}\n","import {\n  defaultColorPalette,\n  mergeColorPalette,\n  type ColorPalette,\n} from \"./color.js\";\n\n/** ANSI palette used by `createLogger` and pause prompts. */\nexport interface ThemePalette {\n  info: string;\n  success: string;\n  warn: string;\n  error: string;\n  /** Muted text (e.g. pause hint). Defaults to gray if omitted. */\n  muted?: string;\n  reset: string;\n}\n\n/**\n * Theme for logs and breadcrumb formatting.\n * Implement in consuming projects for custom colors / separators.\n */\nexport interface ThemeProvider {\n  readonly palette: ThemePalette;\n  formatBreadcrumb(segments: string[]): string;\n}\n\nexport function createThemeFromPalette(palette: ColorPalette): ThemeProvider {\n  return {\n    palette: {\n      info: palette.cyan,\n      success: palette.green,\n      warn: palette.orange,\n      error: palette.red,\n      muted: palette.gray,\n      reset: palette.reset,\n    },\n    formatBreadcrumb(segments: string[]): string {\n      return segments.join(\" > \");\n    },\n  };\n}\n\nexport const defaultTheme: ThemeProvider = createThemeFromPalette(\n  defaultColorPalette,\n);\n\n/**\n * Merge partial ANSI overrides into the default palette and build a theme.\n */\nexport function createThemeFromPartialColors(\n  partial?: Partial<ColorPalette>,\n): ThemeProvider {\n  return createThemeFromPalette(mergeColorPalette(partial));\n}\n","import type { ThemeProvider } from \"./theme.js\";\nimport { defaultTheme } from \"./theme.js\";\n\nexport function createLogger(theme: ThemeProvider) {\n  const { palette } = theme;\n  return {\n    info: (msg: string) => console.log(`${palette.info}${msg}${palette.reset}`),\n\n    success: (msg: string) =>\n      console.log(`${palette.success}${msg}${palette.reset}`),\n\n    warn: (msg: string) => console.log(`${palette.warn}${msg}${palette.reset}`),\n\n    error: (msg: string) => console.log(`${palette.error}${msg}${palette.reset}`),\n  } as const;\n}\n\nexport type Logger = ReturnType<typeof createLogger>;\n\n/** Default logger using `defaultTheme`. */\nexport const log = createLogger(defaultTheme);\n","/** select メニューの初期表示行数（これを超えるとスクロール）。全メニュー共通。 */\nexport const SELECT_PAGE_SIZE = 10;\n\n/** select メニュー共通テーマ。選択行を反転表示で目立たせる。 */\nexport const SELECT_THEME = {\n  icon: { cursor: \"▶\" },\n  style: {\n    highlight: (text: string) => `\\x1b[1;7m ${text} \\x1b[0m`,\n  },\n} as const;\n","import type { BannerConfig, CliScreenLayout } from \"../types.js\";\nimport type { BannerRenderer } from \"./banner-renderer.js\";\nimport { defaultBannerRenderer } from \"./banner-renderer.js\";\n\nconst DEFAULT_BORDER =\n  \"────────────────────────────────────────────────────────────────\";\nconst DEFAULT_TITLE_TEMPLATE = \"【{title}】\";\n\nexport interface ShowScreenOptions {\n  banner?: BannerConfig | (() => void);\n  bannerColor?: string;\n  /** Pre-formatted breadcrumb line (e.g. `TOP > Docker`). */\n  breadcrumb?: string;\n  bannerRenderer?: BannerRenderer;\n  /** Title area: border lines and `{title}` placeholder in `titleTemplate`. */\n  screen?: CliScreenLayout;\n}\n\nexport function showScreen(\n  title = \"Main Menu\",\n  options: ShowScreenOptions = {},\n): void {\n  console.clear();\n  const renderer = options.bannerRenderer ?? defaultBannerRenderer;\n  renderer.print(options.banner, options.bannerColor);\n\n  const border =\n    options.screen?.border !== undefined ? options.screen.border : DEFAULT_BORDER;\n  const titleTemplate =\n    options.screen?.titleTemplate ?? DEFAULT_TITLE_TEMPLATE;\n  const titleLine = titleTemplate.replaceAll(\"{title}\", title);\n\n  if (border.length > 0) {\n    console.log(border);\n  }\n  console.log(titleLine);\n  if (border.length > 0) {\n    console.log(border);\n  }\n\n  if (options.breadcrumb) {\n    console.log(options.breadcrumb);\n  }\n\n  console.log(\"\");\n}\n","import { confirm, select } from \"@inquirer/prompts\";\nimport { readFile } from \"node:fs/promises\";\nimport { dirname, isAbsolute, resolve } from \"node:path\";\nimport {\n  assertNavMenuRefs,\n  type NavMenuAction,\n  type NavMenuConfig,\n  parseNavMenuConfigJson,\n} from \"./config/nav-menu-schema.js\";\nimport { defaultMessages, resolveMessagesForNavConfig, type Messages } from \"./i18n/messages.js\";\nimport { runForeground, runSequential, runStep } from \"./runner.js\";\nimport type { BannerConfig } from \"./types.js\";\nimport type { BannerRenderer } from \"./ui/banner-renderer.js\";\nimport { createDefaultBannerRenderer } from \"./ui/banner-renderer.js\";\nimport { defaultColorPalette, mergeColorPalette } from \"./ui/color.js\";\nimport {\n  resolveBannerColorToken,\n  resolvePartialColors,\n} from \"./ui/color-resolve.js\";\nimport { createLogger } from \"./ui/logger.js\";\nimport { SELECT_PAGE_SIZE, SELECT_THEME } from \"./ui/prompt-config.js\";\nimport { waitForEnter, type WaitForEnterStyle } from \"./ui/pause.js\";\nimport { showScreen } from \"./ui/screen.js\";\nimport { printTable } from \"./ui/table.js\";\nimport { createThemeFromPalette, type ThemeProvider } from \"./ui/theme.js\";\n\nconst CHOICE_BACK = \"__back__\";\nconst CHOICE_TOP = \"__top__\";\nconst CHOICE_EXIT = \"__exit__\";\n\nexport interface CreateCliFromNavConfigOptions {\n  theme?: ThemeProvider;\n  bannerRenderer?: BannerRenderer;\n  resolvedBanner?: BannerConfig;\n  messages?: Messages;\n}\n\ninterface CliRunContext {\n  messages: Messages;\n  pauseStyle: WaitForEnterStyle;\n}\n\nfunction buildBreadcrumb(\n  stack: string[],\n  config: NavMenuConfig,\n  theme: ThemeProvider,\n): string {\n  const segments = stack.map((id) => config.menus[id]?.label ?? id);\n  return theme.formatBreadcrumb(segments);\n}\n\nasync function dispatchAction(\n  action: NavMenuAction,\n  stack: string[],\n  _config: NavMenuConfig,\n  ctx: CliRunContext,\n): Promise<void> {\n  switch (action.type) {\n    case \"menu\":\n      stack.push(action.menuId);\n      return;\n\n    case \"command\": {\n      if (action.mode === \"once\") {\n        runStep({ label: action.label ?? action.cmd, cmd: action.cmd });\n      } else if (action.mode === \"sequential\") {\n        runSequential(action.steps, { messages: ctx.messages });\n      } else {\n        await runForeground(\n          {\n            label: action.label ?? action.cmd,\n            cmd: action.cmd,\n          },\n          { messages: ctx.messages },\n        );\n      }\n      await waitForEnter(ctx.messages.pressEnterToReturn, ctx.pauseStyle);\n      return;\n    }\n\n    case \"table\":\n      printTable(action.headers, action.rows);\n      await waitForEnter(ctx.messages.pressEnterToReturn, ctx.pauseStyle);\n      return;\n\n    case \"confirm\": {\n      const ok = await confirm({ message: action.message });\n      const next = ok ? action.onYes : action.onNo;\n      if (next) {\n        await dispatchAction(next, stack, _config, ctx);\n      }\n      return;\n    }\n  }\n}\n\n/**\n * Interactive CLI from a validated {@link NavMenuConfig} (JSON-driven menus).\n */\nexport async function createCliFromNavConfig(\n  config: NavMenuConfig,\n  options: CreateCliFromNavConfigOptions = {},\n): Promise<void> {\n  assertNavMenuRefs(config);\n\n  const resolvedColors = resolvePartialColors(config.colors);\n\n  const mergedPalette = options.theme\n    ? defaultColorPalette\n    : mergeColorPalette(resolvedColors);\n\n  const theme =\n    options.theme ?? createThemeFromPalette(mergeColorPalette(resolvedColors));\n\n  const bannerRenderer =\n    options.bannerRenderer ??\n    createDefaultBannerRenderer(mergedPalette);\n\n  const messages =\n    options.messages ??\n    resolveMessagesForNavConfig(config.locale, config.messageOverrides);\n\n  const log = createLogger(theme);\n  const pauseStyle: WaitForEnterStyle = {\n    muted: theme.palette.muted ?? mergedPalette.gray,\n    reset: theme.palette.reset,\n  };\n  const ctx: CliRunContext = { messages, pauseStyle };\n\n  const labels = {\n    back: config.labels?.back ?? messages.back,\n    top: config.labels?.top ?? messages.top,\n    exit: config.labels?.exit ?? messages.exit,\n  };\n\n  const stack: string[] = [config.rootMenuId];\n  const screenBase = {\n    banner: options.resolvedBanner ?? config.banner,\n    bannerColor: resolveBannerColorToken(config.bannerColor, mergedPalette),\n    bannerRenderer,\n    screen: config.screen,\n  };\n\n  while (true) {\n    const currentId = stack[stack.length - 1] ?? config.rootMenuId;\n    const menu = config.menus[currentId];\n    if (!menu) {\n      log.error(`Missing menu: ${currentId}`);\n      stack.length = 0;\n      stack.push(config.rootMenuId);\n      continue;\n    }\n\n    const depth = stack.length;\n    const breadcrumb =\n      theme.palette.info +\n      buildBreadcrumb(stack, config, theme) +\n      theme.palette.reset;\n\n    const screenTitle = config.title\n      ? `${config.title} — ${menu.label}`\n      : menu.label;\n\n    showScreen(screenTitle, {\n      ...screenBase,\n      breadcrumb,\n    });\n\n    const choices: { name: string; value: string; description?: string }[] =\n      menu.items.map((item, i) => ({\n        name: item.label,\n        value: `u:${String(i)}`,\n        description: item.description,\n      }));\n\n    if (depth > 1) {\n      choices.push({ name: labels.back, value: CHOICE_BACK });\n      choices.push({ name: labels.top, value: CHOICE_TOP });\n    }\n\n    choices.push({ name: labels.exit, value: CHOICE_EXIT });\n\n    const choice = await select({\n      message: \"Select an action\\n\",\n      choices,\n      loop: false,\n      pageSize: SELECT_PAGE_SIZE,\n      theme: SELECT_THEME,\n    }).catch(() => \"__interrupted__\" as const);\n\n    if (choice === \"__interrupted__\") {\n      log.warn(\"\\nBye! 👋\");\n      process.exit(0);\n    }\n\n    if (choice === CHOICE_EXIT) {\n      log.info(\"\\nBye! 👋\\n\");\n      process.exit(0);\n    }\n\n    if (choice === CHOICE_BACK) {\n      if (stack.length > 1) {\n        stack.pop();\n      }\n      continue;\n    }\n\n    if (choice === CHOICE_TOP) {\n      stack.length = 0;\n      stack.push(config.rootMenuId);\n      continue;\n    }\n\n    if (choice.startsWith(\"u:\")) {\n      const idx = Number(choice.slice(2));\n      const item = menu.items[idx];\n      if (item) {\n        try {\n          await dispatchAction(item.action, stack, config, ctx);\n        } catch {\n          log.error(messages.errorOccurred);\n          await waitForEnter(messages.pressEnterToReturn, pauseStyle);\n        }\n      }\n    }\n  }\n}\n\n/**\n * Load a JSON file and start the nav CLI.\n */\nexport async function createCliFromConfigFile(\n  filePath: string,\n  options?: CreateCliFromNavConfigOptions,\n): Promise<void> {\n  const raw = await readFile(filePath, \"utf8\");\n  const config = parseNavMenuConfigJson(raw);\n  const configDir = dirname(resolve(filePath));\n  const resolvedBanner = await resolveBannerConfig(config.banner, configDir);\n  await createCliFromNavConfig(config, { ...options, resolvedBanner });\n}\n\nasync function resolveBannerConfig(\n  banner: NavMenuConfig[\"banner\"],\n  configDir: string,\n): Promise<BannerConfig | undefined> {\n  if (!banner || typeof banner === \"string\" || banner.type === \"text\") {\n    return banner;\n  }\n\n  const resolvedPath = isAbsolute(banner.path)\n    ? banner.path\n    : resolve(configDir, banner.path);\n  const content = await readFile(resolvedPath, \"utf8\");\n  return {\n    type: \"file\",\n    path: resolvedPath,\n    content,\n  };\n}\n","import { z } from \"zod\";\n\nexport type NavMenuAction =\n  | {\n      type: \"command\";\n      mode: \"once\";\n      cmd: string;\n      label?: string;\n    }\n  | {\n      type: \"command\";\n      mode: \"sequential\";\n      steps: { label: string; cmd: string }[];\n    }\n  | {\n      type: \"command\";\n      mode: \"foreground\";\n      cmd: string;\n      label?: string;\n    }\n  | { type: \"menu\"; menuId: string }\n  | { type: \"table\"; headers: string[]; rows: string[][] }\n  | {\n      type: \"confirm\";\n      message: string;\n      onYes: NavMenuAction;\n      onNo?: NavMenuAction;\n    };\n\nconst commandSchema = z.discriminatedUnion(\"mode\", [\n  z.object({\n    type: z.literal(\"command\"),\n    mode: z.literal(\"once\"),\n    cmd: z.string(),\n    label: z.string().optional(),\n  }),\n  z.object({\n    type: z.literal(\"command\"),\n    mode: z.literal(\"sequential\"),\n    steps: z.array(\n      z.object({\n        label: z.string(),\n        cmd: z.string(),\n      }),\n    ),\n  }),\n  z.object({\n    type: z.literal(\"command\"),\n    mode: z.literal(\"foreground\"),\n    cmd: z.string(),\n    label: z.string().optional(),\n  }),\n]);\n\nconst actionSchema: z.ZodType<NavMenuAction> = z.lazy(() =>\n  z.union([\n    commandSchema,\n    z.object({\n      type: z.literal(\"menu\"),\n      menuId: z.string(),\n    }),\n    z.object({\n      type: z.literal(\"table\"),\n      headers: z.array(z.string()),\n      rows: z.array(z.array(z.string())),\n    }),\n    z.object({\n      type: z.literal(\"confirm\"),\n      message: z.string(),\n      onYes: actionSchema,\n      onNo: actionSchema.optional(),\n    }),\n  ]),\n);\n\nconst menuItemSche