{
  "name": "kd1-labs-playwright",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for E2E test framework and product tests",
  "scripts": {
    "test:e2e": "pnpm --filter @kd1-labs/e2e test",
    "test:e2e:ui": "pnpm --filter @kd1-labs/e2e test:ui",
    "test:e2e:headed": "pnpm --filter @kd1-labs/e2e test:headed",
    "test:e2e:list": "pnpm --filter @kd1-labs/e2e exec playwright test --list",
    "typecheck": "tsc --build",
    "scheduler": "pnpm --filter @kd1-labs/e2e scheduler",
    "cli": "npx navmenu ./cli/navmenu.json"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.18.3",
  "devDependencies": {
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@kd1-labs/navmenu-cli": "^0.1.0"
  }
}
