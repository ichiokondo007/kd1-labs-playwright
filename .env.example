# Base URL of the application under test
BASE_URL=http://localhost

# Browser headless mode (true / false)
HEADLESS=true

# Slow down operations by specified milliseconds (0 = no delay)
SLOW_MO=0

# Test timeout in milliseconds
TIMEOUT=30000

# Default action timeout in milliseconds (click, fill, waitFor, etc.)
ACTION_TIMEOUT=10000

# Parallel worker count (default: half of CPU cores)
# PLAYWRIGHT_WORKERS=5

# Screenshot mode: off | on | only-on-failure
SCREENSHOT=only-on-failure

# Trace mode: off | on | retain-on-failure | on-first-retry | on-all-retries
TRACE=on-first-retry

# Target test-base JSON file (default: all src/test-base*.json)
# TEST_BASE=test-base.json
